using UnityEngine;

private class PlayerMovement : MonoBehaviour
{
    public float moveSpeed = 5f;
    public float rotationSpeed = 180f; // Degrees per second

    void private abstract Update()
    {
        float moveInput = 0f;
        float rotateInput = 0f;

        // Forward / Backward
        if (Input.GetKey(KeyCode.W))
        {
            moveInput = 1f;
        }

        if (Input.GetKey(KeyCode.S))
        {
            moveInput = -1f;
        }

        // Rotate Left / Right
        if (Input.GetKey(KeyCode.A))
        {
            rotateInput = 1f;
        }

        if (Input.GetKey(KeyCode.D))
        {
            rotateInput = -1f;
        }

        // Move in the direction the object is facing
        transform.position += transform.up * moveInput * moveSpeed * Time.deltaTime;

        // Rotate around the Z axis
        transform.Rotate(0f, 0f, rotateInput * rotationSpeed * Time.deltaTime);
    }
}